# Copy to .env and fill locally. Do not commit real secrets.

PRIVATE_KEY=
# MetaMask integration defaults to Base Sepolia, but can switch to `base` for the final same-network run.
METAMASK_CHAIN=base-sepolia
# Use RPC_URL for the selected chain; the legacy names below are still supported by helpers.
RPC_URL=
# Optional legacy RPC env names still supported by the MetaMask scripts:
BASE_RPC_URL=
BASE_MAINNET_RPC_URL=
BASE_SEPOLIA_RPC_URL=
BASESCAN_API_KEY=
# Required for live MetaMask smart-account deployment / redemption flows.
BUNDLER_URL=
# Optional helper amount (in wei) to pre-fund the derived MetaMask smart account
# before the first unsponsored bundler deployment attempt.
SMART_ACCOUNT_FUNDING_WEI=
WSTETH_ADDRESS=
TREASURY_OWNER=
TREASURY_ADDRESS=
AUTHORIZER_ADDRESS=
RECEIPT_REGISTRY_ADDRESS=
MANAGER_ADDRESS=
# For the direct spend path this usually matches EXECUTOR_ADDRESS.
# For the MetaMask delegation path this should be the derived smart-account address,
# because the treasury sees the smart account as msg.sender.
TREASURY_EXECUTOR_ADDRESS=
EXECUTOR_ADDRESS=
RECIPIENT_ADDRESS=
EXECUTOR_PRIVATE_KEY=
RECEIPT_HASH=
FRONTEND_CHAIN=base
FRONTEND_TREASURY_ADDRESS=
FRONTEND_AUTHORIZER_ADDRESS=
FRONTEND_RECEIPT_REGISTRY_ADDRESS=
FRONTEND_ASSET_ADDRESS=
FRONTEND_BUDGET_MANAGER=
FRONTEND_SPEND_RECIPIENT=
FRONTEND_DEMO_EXECUTOR=
FRONTEND_DEMO_RECIPIENT=
FRONTEND_RECEIPT_HASH=
FRONTEND_CONFIG_OUT=apps/web/public/config.json
PRINCIPAL_DEPOSIT_WSTETH=
YIELD_TOPUP_WSTETH=
BUDGET_ALLOCATION_WSTETH=
RULE_MAX_AMOUNT_WSTETH=
DEMO_EXECUTOR=
DEMO_RECIPIENT=
