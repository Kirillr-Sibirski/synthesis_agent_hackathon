FRONTEND_CHAIN=base

# RPC / explorers
RPC_URL=
BASE_MAINNET_RPC_URL=
BASESCAN_API_KEY=
BUNDLER_URL=

# Signers
PRIVATE_KEY=
EXECUTOR_PRIVATE_KEY=

# Core onchain addresses (Base mainnet)
