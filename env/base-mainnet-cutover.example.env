# Base mainnet same-network cutover env template
# Copy values into your local .env before the final run. Do not commit secrets.

# Core chain selection
METAMASK_CHAIN=base
FRONTEND_CHAIN=base

# RPC / explorers
RPC_URL=
BASE_MAINNET_RPC_URL=
BASESCAN_API_KEY=
BUNDLER_URL=
# Optional helper amount (wei) to top up the counterfactual smart account before
# the first unsponsored MetaMask deployment attempt.
SMART_ACCOUNT_FUNDING_WEI=

# Signers
# PRIVATE_KEY should control TREASURY_OWNER.
# EXECUTOR_PRIVATE_KEY should control EXECUTOR_ADDRESS.
PRIVATE_KEY=
EXECUTOR_PRIVATE_KEY=

# Core onchain addresses (Base mainnet)
# Keep these aligned with the signers + final role-separated demo plan.
WSTETH_ADDRESS=0xc1CBa3fCea344f92D9239c08C0568f6F2F0ee452
TREASURY_OWNER=
TREASURY_ADDRESS=
AUTHORIZER_ADDRESS=
RECEIPT_REGISTRY_ADDRESS=
MANAGER_ADDRESS=
# For the MetaMask delegation path this should be the derived smart-account address.
# For the direct executor-only path it can match EXECUTOR_ADDRESS.
TREASURY_EXECUTOR_ADDRESS=
EXECUTOR_ADDRESS=
RECIPIENT_ADDRESS=

# Live demo / treasury setup values
# DEMO_EXECUTOR should normally match EXECUTOR_ADDRESS.
# DEMO_RECIPIENT should normally match RECIPIENT_ADDRESS.
PRINCIPAL_DEPOSIT_WSTETH=
YIELD_TOPUP_WSTETH=
BUDGET_ALLOCATION_WSTETH=
RULE_MAX_AMOUNT_WSTETH=
RECEIPT_HASH=
DEMO_EXECUTOR=
DEMO_RECIPIENT=

# Frontend cutover values (prefer explicit FRONTEND_* for the final demo)
# These should mirror the intended live role-separated story; the validator will warn on mismatches.
# FRONTEND_DEMO_EXECUTOR should normally match TREASURY_EXECUTOR_ADDRESS, because the
# judge-facing receipt proof shows the smart-account executor rather than the redeemer EOA.
FRONTEND_TREASURY_ADDRESS=
FRONTEND_AUTHORIZER_ADDRESS=
FRONTEND_RECEIPT_REGISTRY_ADDRESS=
FRONTEND_ASSET_ADDRESS=0xc1CBa3fCea344f92D9239c08C0568f6F2F0ee452
FRONTEND_BUDGET_MANAGER=
FRONTEND_SPEND_RECIPIENT=
FRONTEND_DEMO_EXECUTOR=
FRONTEND_DEMO_RECIPIENT=
FRONTEND_RECEIPT_HASH=

# Artifact refresh outputs
FRONTEND_CONFIG_OUT=apps/web/public/config.json
PREFLIGHT_OUT=artifacts/metamask/preflight-8453.json
FRONTEND_VALIDATION_OUT=artifacts/frontend/validation.json
FINAL_READINESS_OUT=artifacts/final/same-network-readiness.json
