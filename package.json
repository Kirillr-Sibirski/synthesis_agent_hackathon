{
  "name": "synthesis_agent_hackathon",
  "version": "1.0.0",
  "description": "Foundry-first build for a Synthesis hackathon project centered on a delegated yield treasury primitive for autonomous agents.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "test": "echo \"Use forge test for Solidity and tsx for integration scripts\"",
    "metamask:derive-smart-account": "node --import tsx integrations/metamask/deriveSmartAccount.ts",
    "metamask:deploy-smart-account": "node --import tsx integrations/metamask/deploySmartAccount.ts",
    "metamask:encode-treasury-spend": "node --import tsx integrations/metamask/encodeTreasurySpend.ts",
    "metamask:prepare-delegation-artifact": "node --import tsx integrations/metamask/prepareDelegationArtifact.ts",
    "metamask:create-signed-delegation-artifact": "node --import tsx integrations/metamask/createSignedDelegationArtifact.ts",
    "metamask:redeem-signed-delegation": "node --import tsx integrations/metamask/redeemSignedDelegation.ts",
    "metamask:run-live-flow": "node --import tsx integrations/metamask/runLiveDelegationFlow.ts",
    "metamask:preflight": "node --import tsx integrations/metamask/preflight.ts",
    "frontend:write-config": "node --import tsx integrations/frontend/writeLocalConfig.ts",
    "frontend:validate-config": "node --import tsx integrations/frontend/validateLocalConfig.ts",
    "final:validate-cutover-env": "node --import tsx integrations/final/validateCutoverEnv.ts",
    "final:validate-same-network": "node --import tsx integrations/final/validateSameNetworkReadiness.ts",
    "final:render-cutover-checklist": "node --import tsx integrations/final/renderCutoverChecklist.ts",
    "final:render-cutover-env-checklist": "node --import tsx integrations/final/renderCutoverEnvChecklist.ts",
    "final:refresh-readiness-bundle": "node --import tsx integrations/final/refreshReadinessBundle.ts",
    "submission:refresh-public-agent-artifacts": "node --import tsx integrations/submission/refreshPublicAgentArtifacts.ts",
    "submission:render-public-evidence-pack": "node --import tsx integrations/submission/renderPublicEvidencePack.ts"
  },
  "repository": {
    "type": "git",
    "url": "git@github-synthesis-hackathon:Kirillr-Sibirski/synthesis_agent_hackathon.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@metamask/smart-accounts-kit": "^0.4.0-beta.1",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "viem": "^2.47.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2"
  }
}
